{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "autocut",
  "version": "0.3.1",
  "identifier": "dev.cobanov.autocut",
  "build": {
    "beforeDevCommand": "node_modules/.bin/vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node_modules/.bin/vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "autocut",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
